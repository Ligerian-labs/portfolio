---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import MatrixTrail from '../components/MatrixTrail.astro';
import SeoHead from '../components/SeoHead.astro';
import { site } from '../config/site';
import type { Locale } from '../i18n/ui';
import type { SeoAlternate } from '../lib/seo';
import '../styles/global.css';

type Props = {
  seo: {
    title: string;
    description: string;
    canonical: string;
    type?: 'website' | 'article' | 'profile';
    ogImage?: string;
    alternates?: SeoAlternate[];
  };
  schema?: object | object[];
  locale: Locale;
};

const { seo, schema = [], locale } = Astro.props;
const pathname = Astro.url.pathname;
---

<!doctype html>
<html lang={locale}>
  <head>
    <SeoHead
      title={seo.title}
      description={seo.description}
      canonical={seo.canonical}
      type={seo.type}
      image={seo.ogImage ?? new URL(site.ogImage, site.url).toString()}
      schema={schema}
      locale={locale}
      alternates={seo.alternates ?? []}
    />
  </head>
  <body>
    <MatrixTrail />
    <div class="page-shell">
      <Header pathname={pathname} locale={locale} />
      <main>
        <slot />
      </main>
      <Footer pathname={pathname} locale={locale} />
    </div>
  </body>
</html>
