---
import LanguageSwitcher from './LanguageSwitcher.astro';
import { localizedPath, stripLocale, t, type Locale } from '../i18n/ui';

type Props = {
  pathname?: string;
  locale: Locale;
};

const { pathname = '/', locale } = Astro.props;
const strings = t(locale);
const { rest } = stripLocale(pathname);

const links = [
  { path: '/', label: strings.nav.experience },
  { path: '/projects', label: strings.nav.projects },
  { path: '/contact', label: strings.nav.contact },
] as const;

function isActive(path: string) {
  if (path === '/') return rest === '/';
  return rest.startsWith(path);
}
---

<header class="site-header">
  <a class="brand" href={localizedPath(locale, '/')}>
    <span class="logo-mark">VD</span>
    <strong>Valentin Dosimont</strong>
  </a>

  <nav class="site-nav" aria-label="Primary">
    {links.map((link) => (
      <a
        class="nav-link"
        href={localizedPath(locale, link.path)}
        aria-current={isActive(link.path) ? 'page' : undefined}
      >
        {link.label}
      </a>
    ))}
    <a class="pill--hire" href={localizedPath(locale, '/contact')}>{strings.nav.hire}</a>
    <LanguageSwitcher locale={locale} pathname={pathname} />
  </nav>
</header>
