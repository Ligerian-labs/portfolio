---
import { t, type Locale } from '../i18n/ui';

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const f = t(locale).form;
---

<form
  class="contact-form"
  data-contact-form
  data-status-sending={f.statusSending}
  data-status-ok={f.statusOk}
  data-status-error-fallback={f.statusErrorFallback}
>
  <div class="form-field">
    <label class="form-label" for="cf-name">{f.nameLabel}</label>
    <input class="form-input" id="cf-name" name="name" type="text" autocomplete="name" placeholder={f.namePlaceholder} required />
  </div>

  <div class="form-field">
    <label class="form-label" for="cf-email">{f.emailLabel}</label>
    <input class="form-input" id="cf-email" name="email" type="email" autocomplete="email" placeholder={f.emailPlaceholder} required />
  </div>

  <div class="form-row">
    <div class="form-field">
      <label class="form-label" for="cf-company">{f.companyLabel}</label>
      <input class="form-input" id="cf-company" name="company" type="text" autocomplete="organization" placeholder={f.companyPlaceholder} />
    </div>
    <div class="form-field">
      <label class="form-label" for="cf-website-real">{f.websiteLabel}</label>
      <input class="form-input" id="cf-website-real" name="website-display" type="text" autocomplete="url" placeholder={f.websitePlaceholder} />
    </div>
  </div>

  <label class="form-honeypot" aria-hidden="true">
    Website
    <input name="website" type="text" tabindex="-1" autocomplete="off" />
  </label>

  <div class="form-field">
    <label class="form-label" for="cf-message">{f.messageLabel}</label>
    <textarea class="form-textarea" id="cf-message" name="message" rows="6" placeholder={f.messagePlaceholder} required></textarea>
  </div>

  <div class="form-actions">
    <button class="form-submit" type="submit">
      <svg class="form-submit__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 2L11 13"></path>
        <path d="M22 2l-7 20-4-9-9-4 20-7z"></path>
      </svg>
      {f.submit}
    </button>
    <p class="form-caption">{f.poweredBy}</p>
    <p class="form-status" data-contact-status role="status" aria-live="polite"></p>
  </div>
</form>

<script>
  const form = document.querySelector('[data-contact-form]');
  const status = document.querySelector('[data-contact-status]');

  if (form instanceof HTMLFormElement && status instanceof HTMLElement) {
    const msgSending = form.dataset.statusSending ?? 'Sending...';
    const msgOk = form.dataset.statusOk ?? 'Message sent.';
    const msgErrorFallback = form.dataset.statusErrorFallback ?? 'Unable to send your message right now.';

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      status.textContent = msgSending;
      status.dataset.state = '';

      const formData = new FormData(form);
      formData.delete('website-display');

      try {
        const response = await fetch('/api/contact', {
          method: 'POST',
          body: formData,
        });

        const payload = await response.json();

        if (!response.ok) {
          throw new Error(payload.error || msgErrorFallback);
        }

        form.reset();
        status.textContent = msgOk;
        status.dataset.state = 'ok';
      } catch (error) {
        status.textContent = error instanceof Error ? error.message : msgErrorFallback;
        status.dataset.state = 'error';
      }
    });
  }
</script>
