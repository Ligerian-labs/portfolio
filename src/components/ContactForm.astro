<form class="contact-form" data-contact-form>
  <div class="form-field">
    <label class="form-label" for="cf-name">Name *</label>
    <input class="form-input" id="cf-name" name="name" type="text" autocomplete="name" placeholder="Your name" required />
  </div>

  <div class="form-field">
    <label class="form-label" for="cf-email">Email *</label>
    <input class="form-input" id="cf-email" name="email" type="email" autocomplete="email" placeholder="you@company.com" required />
  </div>

  <div class="form-row">
    <div class="form-field">
      <label class="form-label" for="cf-company">Company</label>
      <input class="form-input" id="cf-company" name="company" type="text" autocomplete="organization" placeholder="Company name" />
    </div>
    <div class="form-field">
      <label class="form-label" for="cf-website-real">Website</label>
      <input class="form-input" id="cf-website-real" name="website-display" type="text" autocomplete="url" placeholder="https://..." />
    </div>
  </div>

  <label class="form-honeypot" aria-hidden="true">
    Website
    <input name="website" type="text" tabindex="-1" autocomplete="off" />
  </label>

  <div class="form-field">
    <label class="form-label" for="cf-message">Message *</label>
    <textarea class="form-textarea" id="cf-message" name="message" rows="6" placeholder="Tell me about the role, the problem, and the team..." required></textarea>
  </div>

  <div class="form-actions">
    <button class="form-submit" type="submit">
      <svg class="form-submit__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 2L11 13"></path>
        <path d="M22 2l-7 20-4-9-9-4 20-7z"></path>
      </svg>
      Send Message
    </button>
    <p class="form-caption">Powered by Resend</p>
    <p class="form-status" data-contact-status role="status" aria-live="polite"></p>
  </div>
</form>

<script>
  const form = document.querySelector('[data-contact-form]');
  const status = document.querySelector('[data-contact-status]');

  if (form instanceof HTMLFormElement && status instanceof HTMLElement) {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      status.textContent = 'Sending...';
      status.dataset.state = '';

      const formData = new FormData(form);
      formData.delete('website-display');

      try {
        const response = await fetch('/api/contact', {
          method: 'POST',
          body: formData,
        });

        const payload = await response.json();

        if (!response.ok) {
          throw new Error(payload.error || 'Unable to send your message right now.');
        }

        form.reset();
        status.textContent = 'Message sent. I will get back to you soon.';
        status.dataset.state = 'ok';
      } catch (error) {
        status.textContent = error instanceof Error ? error.message : 'Unable to send your message right now.';
        status.dataset.state = 'error';
      }
    });
  }
</script>
