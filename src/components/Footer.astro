---
import { site } from '../config/site';
import { stripLocale, t, type Locale } from '../i18n/ui';

type Props = {
  pathname?: string;
  locale: Locale;
};

const { pathname = '/', locale } = Astro.props;
const { rest } = stripLocale(pathname);
const isHome = rest === '/';
const segment = rest.replace(/^\//, '').replace(/\/$/, '') || 'home';
const year = new Date().getFullYear();
const strings = t(locale).footer;
---

<footer class="site-footer">
  {isHome ? (
    <span class="site-footer__left">
      <span class="site-footer__brand">VD</span>
      <span class="site-footer__sep">·</span>
      <span>Valentin Dosimont © {year}</span>
    </span>
  ) : (
    <span class="site-footer__left breadcrumb">
      <span class="breadcrumb__home">~</span>
      <span class="breadcrumb__sep">/</span>
      <span class="breadcrumb__current">{segment}</span>
    </span>
  )}

  <span class="site-footer__right">
    <a class="site-footer__link" href={site.github} rel="noreferrer">{strings.github}</a>
    <a class="site-footer__link" href={`mailto:${site.email}`}>{site.email}</a>
  </span>
</footer>
