---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { site } from '../config/site';
import { contributionHighlights, projectDefinitions } from '../data/projects';
import { getGithubShowcase } from '../lib/github';
import { buildBreadcrumbSchema, buildPersonSchema, buildSeo } from '../lib/seo';

const github = await getGithubShowcase();
const seo = buildSeo({
  title: 'Projects | Valentin Dosimont',
  description:
    'Curated open-source projects across AI systems, developer tooling, and blockchain infrastructure by Valentin Dosimont.',
  path: '/projects',
});

const aiProjects = projectDefinitions.filter((p) => ['marathon', 'claudeswarm'].includes(p.slug));
const tooling = projectDefinitions.filter((p) => ['sqlv', 'autobahn-nvim', 'ccmanager'].includes(p.slug));
---

<Layout
  seo={seo}
  schema={[
    buildPersonSchema(),
    buildBreadcrumbSchema([
      { name: 'Home', path: '/' },
      { name: 'Projects', path: '/projects' },
    ]),
  ]}
>
  <section class="page-hero">
    <span class="breadcrumb">
      <span class="breadcrumb__home">~/</span>
      <span class="breadcrumb__crumb">projects</span>
    </span>
    <div class="page-title-row">
      <span class="page-title-bar" aria-hidden="true"></span>
      <h1 class="page-title">Open Source</h1>
    </div>
    <p class="page-lead">{`Curated projects across AI systems, developer tooling, and blockchain infrastructure.\nEach one built to solve a real problem.`}</p>
    <div class="filter-row" role="tablist">
      <button class="filter-pill is-active" data-filter="all">ALL</button>
      <button class="filter-pill" data-filter="ai">AI SYSTEMS</button>
      <button class="filter-pill" data-filter="tooling">DEV TOOLING</button>
      <button class="filter-pill" data-filter="blockchain">BLOCKCHAIN</button>
    </div>
  </section>

  <section class="section section--no-top project-section" data-section="ai">
    <span class="section-eyebrow section-eyebrow--light">AI Systems</span>
    <div class="card-grid card-grid--2">
      {aiProjects.map((project, i) => (
        <ProjectCard
          project={project}
          signal={github.repos[project.slug]}
          variant="grid"
          bar={i === 0 ? 'primary' : 'light'}
          license={i === 0 ? 'Apache 2.0' : 'Apache 2.0'}
        />
      ))}
    </div>
  </section>

  <section class="section section--tight project-section" data-section="tooling">
    <span class="section-eyebrow">Dev Tooling</span>
    <div class="card-grid card-grid--3">
      {tooling.map((project, i) => {
        const bars = ['primary', 'bright', 'mid'] as const;
        const licenses = ['MIT', undefined, 'MIT'];
        return (
          <ProjectCard
            project={project}
            signal={github.repos[project.slug]}
            variant="grid"
            bar={bars[i] ?? 'primary'}
            license={licenses[i]}
          />
        );
      })}
    </div>
  </section>

  <section class="section section--tight project-section" data-section="contributions">
    <span class="section-eyebrow section-eyebrow--mid">Contributions</span>
    <div class="card-grid card-grid--2">
      {contributionHighlights.map((item) => (
        <article class="contrib-card" data-categories={item.categories.join(' ')}>
          <header class="contrib-card__head">
            <h3 class="contrib-card__name">{item.name}</h3>
            {item.categories.includes('blockchain') && !item.categories.includes('gaming') ? (
              <svg class="contrib-card__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="18" cy="18" r="3"></circle>
                <circle cx="6" cy="6" r="3"></circle>
                <path d="M13 6h3a2 2 0 0 1 2 2v7"></path>
                <line x1="6" y1="9" x2="6" y2="21"></line>
              </svg>
            ) : (
              <svg class="contrib-card__icon contrib-card__icon--gaming" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="6" y1="11" x2="10" y2="11"></line>
                <line x1="8" y1="9" x2="8" y2="13"></line>
                <line x1="15" y1="12" x2="15.01" y2="12"></line>
                <line x1="18" y1="10" x2="18.01" y2="10"></line>
                <path d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.545-.604-6.584-.685-7.258A4 4 0 0 0 17.32 5z"></path>
              </svg>
            )}
          </header>
          <ul class="tag-row">
            {item.categories.map((cat) => (
              <li class="tag-pill" data-cat={cat}>{cat}</li>
            ))}
          </ul>
          <p class="contrib-card__desc">{item.summary}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="gh-cta-row">
    <span class="gh-cta-row__text">Explore all 60+ repositories</span>
    <a class="gh-cta-button" href={site.github} rel="noreferrer">
      <svg class="gh-cta-button__icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 .5a11.5 11.5 0 0 0-3.6 22.4c.6.1.8-.2.8-.5v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2a11.4 11.4 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.6 1.7.2 2.9.1 3.2.7.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.3.8 1 .8 2v3c0 .3.2.6.8.5A11.5 11.5 0 0 0 12 .5z"></path>
      </svg>
      View on GitHub
    </a>
  </section>
</Layout>

<script>
  const pills = document.querySelectorAll<HTMLButtonElement>('.filter-pill[data-filter]');
  const cards = document.querySelectorAll<HTMLElement>('article[data-categories]');
  const sections = document.querySelectorAll<HTMLElement>('.project-section');

  function applyFilter(filter: string) {
    const f = filter === 'tooling' ? ['tooling'] : filter === 'ai' ? ['ai'] : filter === 'blockchain' ? ['blockchain'] : null;

    cards.forEach((card) => {
      if (!f) {
        card.style.display = '';
        return;
      }
      const cats = (card.dataset.categories ?? '').split(/\s+/);
      const matches = f.some((tag) => cats.includes(tag));
      card.style.display = matches ? '' : 'none';
    });

    sections.forEach((section) => {
      const visible = Array.from(section.querySelectorAll<HTMLElement>('article[data-categories]')).some(
        (el) => el.style.display !== 'none',
      );
      section.style.display = visible ? '' : 'none';
    });
  }

  pills.forEach((pill) => {
    pill.addEventListener('click', () => {
      pills.forEach((p) => p.classList.remove('is-active'));
      pill.classList.add('is-active');
      applyFilter(pill.dataset.filter ?? 'all');
    });
  });
</script>
