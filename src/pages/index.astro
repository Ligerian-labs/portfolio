---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { site } from '../config/site';
import { experiences, skills } from '../data/experience';
import { projectDefinitions } from '../data/projects';
import { getGithubShowcase } from '../lib/github';
import { buildBreadcrumbSchema, buildPersonSchema, buildSeo, buildWebsiteSchema } from '../lib/seo';

const github = await getGithubShowcase();
const seo = buildSeo({
  title: site.title,
  description:
    'Infrastructure engineer at the intersection of gaming, AI, and blockchain. Rust, TypeScript, Go, Cairo. Open-source systems and developer tooling by Valentin Dosimont.',
  path: '/',
  type: 'profile',
});

const featured = projectDefinitions.filter((project) => project.featured);
const barCycle = ['primary', 'light', 'bright', 'mid', 'pale'] as const;
---

<Layout
  seo={seo}
  schema={[buildWebsiteSchema(), buildPersonSchema(), buildBreadcrumbSchema([{ name: 'Home', path: '/' }])]}
>
  <section class="hero">
    <div class="hero__avatar">
      <img src={site.avatar} alt="Portrait of Valentin Dosimont" loading="eager" />
    </div>
    <h1 class="hero__headline">I build systems that ship.</h1>
    <p class="hero__subtitle">{`Infrastructure engineer at the intersection of gaming, AI, and blockchain.\nRust · TypeScript · Go · Cairo`}</p>
    <div class="hero__cta">
      <a class="btn btn--primary" href="/projects">View Projects</a>
      <a class="btn btn--outline" href="/contact">Get in Touch</a>
    </div>
  </section>

  <section class="stat-bar">
    <div class="stat-bar__cell">
      <span class="stat-bar__num">60+</span>
      <span class="stat-bar__label">Repos</span>
    </div>
    <span class="stat-bar__divider" aria-hidden="true"></span>
    <div class="stat-bar__cell">
      <span class="stat-bar__num">3</span>
      <span class="stat-bar__label">Sectors</span>
    </div>
    <span class="stat-bar__divider" aria-hidden="true"></span>
    <div class="stat-bar__cell">
      <span class="stat-bar__num">10+</span>
      <span class="stat-bar__label">Yrs Experience</span>
    </div>
  </section>

  <section class="section">
    <span class="section-eyebrow">Featured Work</span>
    <div class="card-grid">
      {featured.map((project, i) => (
        <ProjectCard
          project={project}
          signal={github.repos[project.slug]}
          variant="featured"
          bar={barCycle[i % barCycle.length]}
        />
      ))}
    </div>
  </section>

  <section class="section">
    <span class="section-eyebrow section-eyebrow--bright">Experience</span>
    <ol class="exp-list">
      {experiences.map((exp, i) => (
        <li class="exp-row" data-bar={barCycle[i % barCycle.length]}>
          <span class="exp-row__bar" aria-hidden="true"></span>
          <div class="exp-row__content">
            <span class="exp-row__company">{exp.role} · {exp.company}</span>
            <span class="exp-row__role">{exp.location} · {exp.period}</span>
            <p class="exp-row__summary">{exp.summary}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <section class="section">
    <span class="section-eyebrow section-eyebrow--mid">Stack</span>
    <ul class="stack-row">
      {skills.map((skill) => <li class="stack-pill">{skill}</li>)}
    </ul>
  </section>
</Layout>
